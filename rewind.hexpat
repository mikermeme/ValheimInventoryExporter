#include <type/leb128.pat>
#include <type/base64.pat>

using ZDOVar;
using Prefab;

fn format_vector3(ref auto data){
   return std::format("x:{}, y:{}, z:{}", data.x, data.y, data.z);
};

fn format_quat(ref auto data){
   return std::format("x:{}, y:{}, z:{}, w:{}", data.x, data.y, data.z, data.w);
};

fn format_vector2i(ref auto data){
   return std::format("x:{}, y:{}", data.x, data.y);
};

fn format_zdo(ref auto data){
   return std::format("{}", data.prefab);
};

struct Vector3 {
    float x;
    float y;
    float z;
} [[format("format_vector3")]];

struct Vector2i {
    s32 x;
    s32 y;
} [[format("format_vector2i")]];

struct Quaternion {
    float x;
    float y;
    float z;
    float w;
} [[format("format_quat")]];

struct Header {
    u32 magic;
    u32 count;
    Vector3 offset;
};

struct Item {
   
};

fn items(str datas){
    str data;
    str dec = type::impl::decode_base64(datas);
    for (u32 i = 1, i <  std::string::length(dec), i += 1) {    

        if(dec[i] < 32 ){
            continue;
        }
        data += dec[i]; 
    }  
    std::print(data);
};    

struct StringEntry {
    ZDOVar var;
    type::LEB128 length;
    char value[length];

    if(var == ZDOVar::s_items){
        items(value);
    }
};

fn fun(auto data){
   return std::format("{} | {}", data.var, data.data);
};

struct Array<T> {
    ZDOVar var;
    
    if(var == ZDOVar::s_utilityItem){
     Prefab data;
    } else {
     T data;
    }
    
   
}  [[format("fun")]];;


struct ZDO {
    u64 userID;
    u32 ID;
    padding[6];
    u16 ownerRevision;
    u32 dataRevision;
    bool persistant;
    s64 userKey;
    s64 timeCreated;
    u32 zero;
    s8 type;
    bool distant;
    Prefab prefab;
    Vector2i sector;
    Vector3 position;
    Quaternion rotation;
    u8 floatCount;
    Array<float> floats[floatCount];
    u8 vec3Count;
    Array<Vector3> vec3s[vec3Count];
    u8 quatCount;
    Array<Quaternion> quaternions[quatCount];
    u8 intCount;
    Array<u32> ints[intCount];
    u8 longCount;
    Array<u64> longs[longCount];
    u8 stringCount;
    StringEntry strings[stringCount];
    u8 byteCount;
}  [[format("format_zdo")]];;

struct File {
    Header mHeader;
    ZDO zdos[mHeader.count];
};

File file_at_0x0 @ 0x00;

